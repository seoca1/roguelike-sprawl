  "stage_event_bus": {
    "name_en": "Stage Event Bus",
    "name_ko": "스테이지 이벤트 버스",
    "description_en": "Pub/sub for stage lifecycle events. Subscribe globally, by kind, or by stage.",
    "description_ko": "스테이지 라이프사이클 이벤트 Pub/Sub. 전역, 종류별, 스테이지별로 구독.",
    "event_kinds": [
      {
        "id": "enter",
        "name_en": "Stage Enter",
        "name_ko": "스테이지 진입",
        "description_en": "Fired when entering a stage."
      },
      {
        "id": "exit",
        "name_en": "Stage Exit",
        "name_ko": "스테이지 이탈",
        "description_en": "Fired when leaving a stage."
      },
      {
        "id": "complete",
        "name_en": "Stage Complete",
        "name_ko": "스테이지 완료",
        "description_en": "Fired when a stage's objective is satisfied."
      },
      {
        "id": "failed",
        "name_en": "Run Failed",
        "name_ko": "Run 실패",
        "description_en": "Fired when the run transitions to FAILED."
      },
      {
        "id": "advance",
        "name_en": "Stage Advance",
        "name_ko": "스테이지 전이",
        "description_en": "Fired on any stage transition."
      }
    ],
    "subscription_methods": [
      "subscribe(handler) — all events",
      "subscribe_kind(kind, handler) — specific kind",
      "subscribe_stage(kind, stage, handler) — specific stage + kind"
    ]
  },
  "death_flow": {
    "name_en": "Death Flow (Pillar 3: The Flatline)",
    "name_ko": "사망 흐름 (Pillar 3: 플랫라인)",
    "description_en": "Triggered on combat defeat. Equipment lost, grade preserved.",
    "description_ko": "전투 패배 시 발생. 장비 손실, 등급 유지.",
    "ascii_art": [
      "  COMBAT DEFEAT",
      "         ↓",
      "  trigger_death() called",
      "         ↓",
      "  state.is_dead = True",
      "         ↓",
      "  mark_failed() called",
      "         ↓",
      "  FAILED stage entered",
      "         ↓",
      "  DEATH SCREEN rendered",
      "         ↓",
      "  player presses ENTER",
      "         ↓",
      "  mark_death_restart() called",
      "         ↓",
      "  DEATH_RESTART stage",
      "         ↓",
      "  player chooses [ENTER] restart / [ESC] quit",
      "         ↓",
      "  (back to PENDING for new run)"
    ],
    "steps": [
      {
        "id": "defeat",
        "name_en": "Combat Defeat",
        "name_ko": "전투 패배",
        "description_en": "Player HP reaches 0 in combat.",
        "description_ko": "전투 중 플레이어 HP 0 도달."
      },
      {
        "id": "trigger",
        "name_en": "Death Triggered",
        "name_ko": "사망 트리거",
        "description_en": "death.trigger_death() called from combat_view._end_combat().",
        "description_ko": "combat_view._end_combat() 에서 death.trigger_death() 호출."
      },
      {
        "id": "screen",
        "name_en": "Death Screen",
        "name_ko": "사망 화면",
        "description_en": "ASCII skull with avatar, 'FLATLINE' text, prompt to restart.",
        "description_ko": "아바타와 함께 ASCII 해골, 'FLATLINE' 텍스트, 재시작 프롬프트."
      },
      {
        "id": "restart",
        "name_en": "Jack Out to Hub",
        "name_ko": "잭아웃 → Hub",
        "description_en": "ENTER pressed. Player returns to Hub. Inventory cleared, grade preserved.",
        "description_ko": "ENTER 입력. 플레이어 Hub 복귀. 인벤토리 초기화, 등급 유지."
      }
    ]
  },
  "hub_loop": {
    "name_en": "Hub Loop (Main Game Loop)",
    "name_ko": "허브 루프 (메인 게임 루프)",
    "description_en": "Between runs, player is at the Hub. Accept missions, talk to NPCs, manage equipment.",
    "description_ko": "Run 사이, 플레이어는 Hub에 있음. 미션 수락, NPC 대화, 장비 관리.",
    "ascii_art": [
      "  ┌────────────────────────┐",
      "  │  HUB — Between Runs    │",
      "  │                        │",
      "  │  [1] Mission board     │",
      "  │  [2] Equipment         │",
      "  │  [3] Talk to Wim       │",
      "  │  [4] Talk to Finn      │",
      "  │  [5] Sleep (heal)      │",
      "  │                        │",
      "  │  → Accept mission      │",
      "  │     → Stage: meet_npc  │",
      "  │     → Jack in          │",
      "  │     → Matrix: ...      │",
      "  │     → Jack out         │",
      "  │     → Stage: reward    │",
      "  │     → Return to Hub    │",
      "  └────────────────────────┘"
    ]
  }
}