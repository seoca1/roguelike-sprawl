      "secondary_objective_ko": "ICE 1개 격파 (Wisp급)",
      "rewards": {
        "credits": 500,
        "materials": {"data_fragment": 2}
      },
      "estimated_minutes": 8
    },
    {
      "id": "watchdog_patrol",
      "title_en": "Watchdog Patrol",
      "title_ko": "와치독 순찰",
      "fixer": "finn",
      "arc": 1,
      "grade_min": 1,
      "grade_max": 1,
      "stages": ["meet_npc", "defeat_ice", "jack_out", "reward", "complete"],
      "primary_objective_en": "Defeat 2 ICE (Watchdog-class)",
      "primary_objective_ko": "ICE 2개 격파 (Watchdog급)",
