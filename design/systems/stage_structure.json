    {
      "id": "ice_run",
      "title_en": "Ice Run",
      "title_ko": "아이스 런",
      "fixer": "finn",
      "arc": 1,
      "grade_min": 1,
      "grade_max": 2,
      "stages": ["meet_npc", "extract_data", "defeat_ice", "jack_out", "reward", "complete"],
      "primary_objective_en": "Collect 5 ice_shard",
      "primary_objective_ko": "ice_shard 5개 수집",
      "secondary_objective_en": "Defeat 2 ICE (Wisp-class)",
