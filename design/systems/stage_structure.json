{
  "version": "0.2.0",
  "title": "Stage Structure & Progression",
  "title_ko": "스테이지 구조 & 진행",
  "description": "Single Run = PENDING → Mission flow (per-mission) → COMPLETE/FAILED. v0.2: JACK_OUT, REWARD, DEBRIEF, DEATH_RESTART added.",
  "stages": [
    {
      "id": "pending",
      "name_en": "Pending",
      "name_ko": "대기",
      "type": "hub",
      "is_terminal": false,
      "objective_kind": "none",
      "description_en": "Run not started. Player is at the Hub.",
      "description_ko": "Run 미시작. 플레이어는 Hub에 있음.",
      "next_stage": "meet_npc",
      "trigger_en": "Accept a mission at the Hub.",
      "trigger_ko": "Hub에서 미션을 수락.",
      "ascii_art": [
        "  ┌──────────────────────┐",
        "  │  HUB — The Sprawl Hole │",
        "  │  ◢◣◢◣◢◣◢◣◢◣◢◣◢◣◢◣◢◣  │",
        "  │  ░▒▓█ Wim's bar  ▓▒░  │",
        "  │  ░▒▓█ Job board  ▓▒░  │",
        "  │  ░▒▓█ Couch      ▓▒░  │",
        "  └──────────────────────┘"
      ],
      "ui_elements": ["hub_view", "mission_board", "wim_dialogue"]
    },
    {
      "id": "meet_npc",
      "name_en": "Meet the NPC",
      "name_ko": "NPC 만나기",
      "type": "matrix",
      "is_terminal": false,
      "objective_kind": "npc",
      "description_en": "Find and talk to a construct NPC (e.g. Dixie Flatline).",
      "description_ko": "구성체 NPC (예: Dixie Flatline) 를 만나서 대화.",
      "next_stage": "extract_data",
      "trigger_en": "Talk to the construct NPC node in the matrix.",
      "trigger_ko": "매트릭스의 구성체 NPC 노드와 대화.",
      "ascii_art": [
        "  ░░░░░░░░░░░░░░░░░░░░░░",
        "  ░  MATRIX — Surface ░",
        "  ░  ◢◣◢◣◢◣◢◣◢◣◢◣◢◣  ░",
        "  ░                     ░",
        "  ░  ★ Dixie (CONSTRUCT) ░",
        "  ░  ░ data            ░",
        "  ░  ▲ ice             ░",
        "  ░░░░░░░░░░░░░░░░░░░░░░"
      ],
      "ui_elements": ["matrix_view", "npc_dialogue", "status_panel"]
    },
    {
      "id": "extract_data",
      "name_en": "Extract the Data",
      "name_ko": "데이터 추출",
      "type": "matrix",
      "is_terminal": false,
      "objective_kind": "data",
      "description_en": "Locate the data node and extract the payload.",
      "description_ko": "데이터 노드를 찾아 페이로드를 추출.",
      "next_stage": "defeat_ice",
      "trigger_en": "Click the data node and confirm extraction.",
      "trigger_ko": "데이터 노드를 클릭하고 추출 확정.",
      "ascii_art": [
        "  ░░░░░░░░░░░░░░░░░░░░░░",
        "  ░  MATRIX — Surface ░",
        "  ░  ◢◣◢◣◢◣◢◣◢◣◢◣◢◣  ░",
        "  ░                     ░",
        "  ░  ✓ Dixie talked    ░",
        "  ░  ★ data (TARGET)   ░",
        "  ░  ▲ ice             ░",
        "  ░░░░░░░░░░░░░░░░░░░░░░"
      ],
      "ui_elements": ["matrix_view", "extract_action", "status_panel"]
    },
    {
      "id": "defeat_ice",
      "name_en": "Defeat the ICE",
      "name_ko": "ICE 격파",
      "type": "combat",
      "is_terminal": false,
      "objective_kind": "ice",
      "description_en": "Engage and defeat the ICE protecting the data.",
      "description_ko": "데이터를 지키는 ICE와 교전하여 격파.",
      "next_stage": "jack_out",
      "trigger_en": "Win the combat (HP > 0, ICE HP = 0).",
      "trigger_ko": "전투 승리 (HP > 0, ICE HP = 0).",
      "ascii_art": [
        "  ░░░░░░░░░░░░░░░░░░░░░░",
        "  ░  COMBAT — RT-MS    ░",
        "  ░  ◢◣◢◣◢◣◢◣◢◣◢◣◢◣  ░",
        "  ░                     ░",
        "  ░  ▶ Player  HP 18/20 ░",
        "  ░  ▲ ICE     HP 12/12 ░",
        "  ░  [E] skill [R] run  ░",
        "  ░░░░░░░░░░░░░░░░░░░░░░"
      ],
      "ui_elements": ["combat_view", "skill_menu", "status_panel"]
    },
    {
      "id": "jack_out",
      "name_en": "Jack Out",
      "name_ko": "잭아웃",
      "type": "animation",
      "is_terminal": false,
      "objective_kind": "none",
      "description_en": "Disconnecting from the matrix. Animation + transition.",
      "description_ko": "매트릭스에서 연결 해제. 애니메이션 + 전환.",
      "next_stage": "reward",
      "trigger_en": "Player presses any key to dismiss.",
      "trigger_ko": "플레이어가 아무 키나 눌러 닫기.",
      "ascii_art": [
        "  ░░░░░░░░░░░░░░░░░░░░░░░░░░",
        "  ░  ◢◣◢◣◢◣◢◣◢◣◢◣◢◣  ░",
        "  ░  ── JACKING OUT ──     ░",
        "  ░  ░▒▓█             ▓▒░  ░",
        "  ░  ░▒▓█             ▓▒░  ░",
        "  ░░░░░░░░░░░░░░░░░░░░░░░░░░"
      ],
      "ui_elements": ["jackout_animation", "press_any_key"]
    },
    {
      "id": "reward",
      "name_en": "Mission Rewards",
      "name_ko": "미션 보상",
      "type": "hub",
      "is_terminal": false,
      "objective_kind": "none",
      "description_en": "Show mission rewards: credits, materials, intel.",
      "description_ko": "미션 보상 표시: 크레딧, 재료, 정보.",
      "next_stage": "complete",
      "trigger_en": "Player presses ENTER to return to hub.",
      "trigger_ko": "플레이어가 ENTER를 눌러 Hub 복귀.",
      "ascii_art": [
        "  ┌──────────────────────┐",
        "  │  ✓ MISSION COMPLETE  │",
        "  │  ◢◣◢◣◢◣◢◣◢◣◢◣◢◣◢◣◢◣  │",
        "  │  ░▒▓ Credits  +500  ▓▒░  │",
        "  │  ░▒▓ Materials +2   ▓▒░  │",
        "  │  ░▒▓ Press ENTER    ▓▒░  │",
        "  └──────────────────────┘"
      ],
      "ui_elements": ["reward_screen", "credits_display", "materials_display"]
    },
    {
      "id": "debrief",
      "name_en": "Debrief",
      "name_ko": "데브리핑",
      "type": "hub",
      "is_terminal": false,
      "objective_kind": "none",
      "description_en": "Optional narrative between COMPLETE and Hub return. World-building, intel unlocked.",
      "description_ko": "COMPLETE와 Hub 복귀 사이 선택적 내러티브. 세계관, 정보 unlock.",
      "next_stage": "complete",
      "trigger_en": "Player dismisses the debrief message.",
      "trigger_ko": "플레이어가 데브리핑 메시지 닫기.",
      "ascii_art": [
        "  ┌──────────────────────┐",
        "  │  📜 DEBRIEF          │",
        "  │  ◢◣◢◣◢◣◢◣◢◣◢◣◢◣◢◣◢◣  │",
        "  │  ░▒▓ 'The Finn's    ▓▒░  │",
        "  │  ░▒▓  gone. T-A     ▓▒░  │",
        "  │  ░▒▓  is watching.' ▓▒░  │",
        "  └──────────────────────┘"
      ],
      "ui_elements": ["debrief_overlay", "intel_unlock"]
    },
    {
      "id": "complete",
      "name_en": "Run Complete",
      "name_ko": "Run 완료",
      "type": "hub",
      "is_terminal": true,
      "objective_kind": "none",
      "description_en": "Mission complete. Return to hub for next job.",
      "description_ko": "미션 완료. 다음 의뢰를 위해 Hub 복귀.",
      "next_stage": null,
      "trigger_en": "Auto-transition from REWARD (or DEBRIEF if enabled).",
      "trigger_ko": "REWARD에서 자동 전환 (또는 DEBRIEF 활성화 시).",
      "ascii_art": [
        "  ┌──────────────────────┐",
        "  │  ✓ RUN COMPLETE     │",
        "  │  ◢◣◢◣◢◣◢◣◢◣◢◣◢◣◢◣◢◣  │",
        "  │  ░▒▓ → Hub         ▓▒░  │",
        "  └──────────────────────┘"
      ],
      "ui_elements": ["mission_summary", "return_to_hub"]
    },
    {
      "id": "death_restart",
      "name_en": "Death Restart",
      "name_ko": "재시작",
      "type": "death",
      "is_terminal": true,
      "objective_kind": "none",
      "description_en": "After death screen. Player chooses to restart or quit.",
      "description_ko": "사망 화면 후. 재시작 또는 종료 선택.",
      "next_stage": "pending",
      "trigger_en": "Player presses ENTER to restart, ESC to quit.",
      "trigger_ko": "ENTER로 재시작, ESC로 종료.",
      "ascii_art": [
        "  ┌──────────────────────┐",
        "  │  ⚠ FLATLINE         │",
        "  │  ◢◣◢◣◢◣◢◣◢◣◢◣◢◣◢◣◢◣  │",
        "  │  ░▒▓ Equipment LOST ▓▒░  │",
        "  │  ░▒▓ Grade kept     ▓▒░  │",
        "  │  ░▒▓ [ENTER] restart ▓▒░  │",
        "  │  ░▒▓ [ESC]   quit    ▓▒░  │",
        "  └──────────────────────┘"
      ],
      "ui_elements": ["death_screen", "restart_prompt"]
    },
    {
      "id": "failed",
      "name_en": "Flatline",
      "name_ko": "플랫라인",
      "type": "death",
      "is_terminal": true,
      "objective_kind": "none",
      "description_en": "Your run ended in cyberspace.",
      "description_ko": "Run 종료.",
      "next_stage": "death_restart",
      "trigger_en": "Combat defeat (HP = 0) or matrix trap.",
      "trigger_ko": "전투 패배 (HP = 0) 또는 매트릭스 함정.",
      "ascii_art": [
        "  ┌──────────────────────┐",
        "  │  ✗ FLATLINE          │",
        "  │  ◢◣◢◣◢◣◢◣◢◣◢◣◢◣◢◣◢◣  │",
        "  │  ░▒▓ Equipment LOST ▓▒░  │",
        "  │  ░▒▓ Grade kept     ▓▒░  │",
        "  └──────────────────────┘"
      ],
      "ui_elements": ["death_screen", "jack_out_to_hub"]
    }
  ],
  "transitions": [
    {
      "from": "pending",
      "to": "meet_npc",
      "trigger_en": "Mission accepted at Hub",
      "trigger_ko": "Hub에서 미션 수락",
      "system": "start_run(mission_id)"
    },
    {
      "from": "meet_npc",
      "to": "extract_data",
      "trigger_en": "Talked to construct NPC",
      "trigger_ko": "구성체 NPC와 대화 완료",
      "system": "RunState.mark_advance() after dialogue"
    },
    {
      "from": "extract_data",
      "to": "defeat_ice",
      "trigger_en": "Data extracted",
      "trigger_ko": "데이터 추출 완료",
      "system": "RunState.mark_advance() after extract"
    },
    {
      "from": "defeat_ice",
      "to": "jack_out",
      "trigger_en": "ICE defeated (HP > 0)",
      "trigger_ko": "ICE 격파 (HP > 0)",
      "system": "RunState.mark_advance() after combat victory"
    },
    {
      "from": "jack_out",
      "to": "reward",
      "trigger_en": "Player dismisses jackout animation",
      "trigger_ko": "잭아웃 애니메이션 닫기",
      "system": "RunState.mark_advance() after input"
    },
    {
      "from": "reward",
      "to": "complete",
      "trigger_en": "Player presses ENTER",
      "trigger_ko": "ENTER 입력",
      "system": "RunState.mark_advance() after input"
    },
    {
      "from": "debrief",
      "to": "complete",
      "trigger_en": "Player dismisses debrief",
      "trigger_ko": "데브리핑 닫기",
      "system": "RunState.mark_advance() after input"
    },
    {
      "from": "any",
      "to": "failed",
      "trigger_en": "Player HP = 0 (combat) or matrix trap",
      "trigger_ko": "플레이어 HP = 0 (전투) 또는 매트릭스 함정",
      "system": "RunState.mark_failed()"
    },
    {
      "from": "failed",
      "to": "death_restart",
      "trigger_en": "Death screen dismissed",
      "trigger_ko": "사망 화면 닫기",
      "system": "RunState.mark_death_restart()"
    }
  ],
  "missions": [
    {
      "id": "first_jack",
      "title_en": "First Jack",
      "title_ko": "첫 잭-인",
      "fixer": "finn",
      "arc": 1,
      "grade_min": 1,
      "grade_max": 1,
      "stages": ["meet_npc", "extract_data", "defeat_ice", "jack_out", "reward", "complete"],
      "primary_objective_en": "Extract demo_file from Sense/Net",
      "primary_objective_ko": "Sense/Net에서 demo_file 추출",
